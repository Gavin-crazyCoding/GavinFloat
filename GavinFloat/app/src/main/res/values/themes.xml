<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- AIDE 兼容主题：使用 AppCompat 代替 MaterialComponents -->
    <style name="Theme.GavinFloat" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/text_blue</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/text_blue</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.GavinFloat.Transparent">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Theme.GavinFloat.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorPrimary">@color/text_blue</item>
        <item name="colorAccent">@color/premium_gold</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimBottom</item>
    </style>

    <style name="DialogAnimBottom" parent="android:Animation">
        <item name="android:windowEnterAnimation">@android:anim/slide_in_left</item>
        <item name="android:windowExitAnimation">@android:anim/slide_out_right</item>
    </style>

    <style name="Theme.GavinFloat.Ball">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
